\n","    return np.nan\n","\n","df['Litho2'] = df['DEPTH'].apply(get_lith)\n","\n","# map lithology → colors\n","color_map = {lith: color for _, _, lith, color in litho}\n","\n","# =========================\n","# SCATTER PLOT\n","# =========================\n","plt.figure(figsize=(8,6))\n","\n","for lith, color in color_map.items():\n","    temp = df[df['Litho2'] == lith]\n","    plt.scatter(\n","        temp['GR'],\n","        temp['Actual_PP'],\n","        s=15,\n","        alpha=0.7,\n","        color=color,\n","        label=lith\n","    )\n","\n","plt.xlabel(\"Gamma Ray (GR)\")\n","plt.ylabel(\"Pore Pressure (Actual_PP)\")\n","plt.title(\"GR vs Pore Pressure (Lithology Colored)\")\n","plt.grid(True, alpha=0.3)\n","plt.legend()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":564},"id":"fh5wkLmaNFtM","executionInfo":{"status":"ok","timestamp":1780200345575,"user_tz":-330,"elapsed":422,"user":{"displayName":"Nikhil Kumar","userId":"15055822279857591511"}},"outputId":"bd06dc25-58c2-483c-a85c-b9b0b9b87cbe"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 800x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":[],"metadata":{"id":"diUsni5mrC5U"},"execution_count":null,"outputs":[]}]}